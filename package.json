{
  "name": "cashbook",
  "version": "0.3.0",
  "description": "Personal cashbook — mobile-first expense tracking PWA with Google Sheets sync",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint \"js/**/*.js\" sw.js",
    "lint:fix": "eslint --fix \"js/**/*.js\" sw.js",
    "format": "prettier --write \"**/*.{js,css,html,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,css,html,json,md}\"",
    "validate:html": "html-validate index.html",
    "serve": "python3 -m http.server 8000",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "html-validate": "^9.0.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.0.0",
    "vitest": "^2.1.9"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kmes6817/cashbook.git"
  }
}
